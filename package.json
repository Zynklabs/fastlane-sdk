  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "tsc",
    "proto:gen": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/stubs --ts_proto_opt=outputServices=nice-grpc,outputServices=generic-definitions,env=node,useOptionals=messages,snakeToCamel=true -I ./proto proto/*.proto"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@zynk/fastlane": "github:Zynklabs/fastlane-sdk",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@grpc/grpc-js": "^1.14.3",
    "nice-grpc": "^2.1.14"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@solana/web3.js": "^1.95.0",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "@coral-xyz/anchor": {
      "optional": true
    }
  }
