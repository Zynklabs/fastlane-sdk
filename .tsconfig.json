{
  "compilerOptions": {
    "incremental": false,
    "tsBuildInfoFile": ".tsbuildinfo",
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "sdk",
    "paths": {
      "*": [
        "*"
      ]
    }
  },
  "include": [
    "sdk/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}